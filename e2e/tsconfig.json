{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": [
    "src",
    "cli",
    "cloud",
    "cloudflare",
    "desktop",
    "desktop-kvm",
    "desktop-packaged",
    "harness",
    "local",
    "scenarios",
    "selfhost",
    "setup",
    "targets",
    "scripts",
    "viewer",
    "vitest.config.ts"
  ]
}
