{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bun install --frozen-lockfile --minimum-release-age=0",
  "experimentalServices": {
    "web": {
      "type": "web",
      "entrypoint": "apps/open-agents",
      "framework": "nextjs",
      "mount": "/",
      "buildCommand": "bun run build"
    },
    "eve": {
      "type": "web",
      "entrypoint": "apps/open-agents",
      "framework": "eve",
      "mount": "/_eve_internal/eve",
      "buildCommand": "bun run scripts/verify-eve-vercel-output-patch.ts && eve build && bun run scripts/patch-eve-vercel-output.ts"
    }
  }
}
