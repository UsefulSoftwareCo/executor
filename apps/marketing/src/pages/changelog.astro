---
export const prerender = true;

import { marked } from "marked";

import Layout from "../layouts/Layout.astro";
import { parseChangelog, type ChangelogRelease } from "../lib/changelog";
import markdown from "../../../cli/CHANGELOG.md?raw";

const GH = "https://github.com/UsefulSoftwareCo/executor";
const releases = parseChangelog(markdown);

type RegistryMetadata = {
  time?: Record<string, string>;
};

const loadReleaseDates = async (): Promise<Map<string, Date>> => {
  try {
    const response = await fetch("https://registry.npmjs.org/executor");
    if (!response.ok) return new Map();
    const metadata = (await response.json()) as RegistryMetadata;
    return new Map(
      Object.entries(metadata.time ?? {}).flatMap(([version, value]) => {
        const date = new Date(value);
        return Number.isNaN(date.getTime()) ? [] : [[version, date] as const];
      }),
    );
  } catch {
    return new Map();
  }
};

const releaseDates = await loadReleaseDates();

const fmt = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });

const htmlFor = (body: string) => marked.parse(body, { async: false });

const viewModel = releases.map((release: ChangelogRelease) => ({
  ...release,
  date: releaseDates.get(release.version),
  entries: release.entries.map((entry) => ({
    ...entry,
    html: htmlFor(entry.body),
  })),
}));
---

<Layout
  title="Changelog — Executor"
  description="Every release of Executor, in order."
>
  <main class="bg-soft relative min-h-dvh antialiased">
    <div
      class="pattern-bg pattern-graph"
      style="position:absolute;top:0;left:0;right:0;height:60vh;z-index:1;pointer-events:none;"
    >
    </div>
    <div
      style="position:absolute;top:0;left:0;right:0;height:60vh;z-index:2;pointer-events:none;background:linear-gradient(180deg,transparent 0%,transparent 55%,var(--color-surface) 100%);"
    >
    </div>

    <div class="relative z-10">
      {/* ─── NAV ─── */}
      <nav>
        <div
          class="mx-auto flex h-14 max-w-[1200px] items-center justify-between px-6 sm:px-10"
        >
          <a href="/" class="flex items-center gap-2.5">
            <img src="/favicon-192.png" alt="" class="h-5 w-5" />
            <span class="text-[15px] font-semibold tracking-[-0.01em] text-ink"
              >executor</span
            >
          </a>
          <div class="flex items-center gap-5">
            <a
              href="/blog"
              class="text-[14px] font-medium text-ink-2 transition-colors hover:text-ink"
              >Blog</a
            >
            <a
              href="/changelog"
              class="text-[14px] font-medium text-ink transition-colors"
              >Changelog</a
            >
            <a
              href="https://executor.sh/docs"
              class="hidden text-[14px] font-medium text-ink-2 transition-colors hover:text-ink sm:inline"
              >Docs</a
            >
            <a
              href={GH}
              class="text-[14px] font-medium text-ink-2 transition-colors hover:text-ink"
              >GitHub</a
            >
            <a href="/#install" class="btn-primary">Get started →</a>
          </div>
        </div>
      </nav>

      {/* ─── HEADER ─── */}
      <section class="px-6 pt-16 pb-10 sm:px-10 sm:pt-24 sm:pb-12">
        <div class="mx-auto max-w-[760px]">
          <h1
            class="text-[clamp(2.4rem,5.6vw,4rem)] font-semibold leading-[1.02] tracking-[-0.025em] text-ink"
          >
            Changelog
          </h1>
          <p class="mt-5 max-w-[54ch] text-[17px] leading-[1.6] text-ink-2 text-pretty">
            Every release of Executor, in order.
          </p>
        </div>
      </section>

      {/* ─── RELEASES ─── */}
      <section class="px-6 pb-24 sm:px-10 sm:pb-32">
        <div class="surface-card mx-auto max-w-[760px]">
          {
            viewModel.map((release, index) => (
              <section
                id={`v${release.version}`}
                class:list={[
                  "px-6 py-7 sm:px-7",
                  index > 0 && "border-t border-rule",
                ]}
              >
                <div class="mb-5 flex flex-col gap-1.5 sm:flex-row sm:items-baseline sm:justify-between">
                  <h2 class="font-mono text-[18px] font-semibold text-ink">
                    v{release.version}
                  </h2>
                  {release.date && (
                    <time
                      datetime={release.date.toISOString()}
                      class="font-mono text-[12px] uppercase tracking-[0.14em] text-ink-3"
                    >
                      {fmt(release.date)}
                    </time>
                  )}
                </div>
                <div class="flex flex-col gap-7">
                  {release.entries.map((entry) => (
                    <article class="blog-prose text-[15.5px] leading-[1.7]">
                      <div set:html={entry.html} />
                      {entry.prNumber && entry.prUrl && (
                        <a
                          href={entry.prUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="mt-3 inline-flex font-mono text-[12px] uppercase tracking-[0.12em] text-ink-3 no-underline transition-colors hover:text-ink"
                        >
                          PR #{entry.prNumber}
                        </a>
                      )}
                    </article>
                  ))}
                </div>
              </section>
            ))
          }
        </div>
      </section>

      {/* ─── FOOTER ─── */}
      <footer class="border-t border-rule py-10">
        <div
          class="mx-auto flex max-w-[1200px] flex-col items-start justify-between gap-6 px-6 sm:flex-row sm:items-center sm:px-10"
        >
          <div class="flex items-center gap-2.5">
            <img src="/favicon-192.png" alt="" class="h-4 w-4 opacity-80" />
            <span class="text-[13px] font-medium text-ink-2">executor</span>
            <span class="ml-2 text-[12px] text-ink-3"
              >© {new Date().getFullYear()}</span
            >
          </div>
          <div class="flex items-center gap-6 text-[13px] text-ink-2">
            <a href="/blog" class="transition-colors hover:text-ink">Blog</a>
            <a href="/changelog" class="transition-colors hover:text-ink"
              >Changelog</a
            >
            <a
              href="https://executor.sh/docs"
              class="transition-colors hover:text-ink">Docs</a
            >
            <a href={GH} class="transition-colors hover:text-ink">GitHub</a>
            <a href="/privacy" class="transition-colors hover:text-ink">Privacy</a>
            <a href="/terms" class="transition-colors hover:text-ink">Terms</a>
          </div>
        </div>
      </footer>
    </div>
  </main>
</Layout>
